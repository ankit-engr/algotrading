# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=BankNiftyAISignalApp
APP_VERSION=1.0.0
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL Connection
DATABASE_URL=mysql://username:password@localhost:3306/stock

# ─── Signal Engine ────────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=70          # Minimum confidence score to issue BUY CE/PE
MIN_VOLUME_SURGE_RATIO=1.5       # Volume must be 1.5x avg to count as surge

# ─── Market Timings (IST, 24h format) ────────────────────────────────────────
MARKET_OPEN_TIME=09:15
MARKET_CLOSE_TIME=15:30
CARRY_FORWARD_TIME=15:15         # Time to run carry-forward engine

# ─── AI Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=./models/signal_model.joblib
RETRAIN_INTERVAL_DAYS=7          # Auto-retrain every N days
MIN_TRAINING_SAMPLES=200         # Minimum samples required to train

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR

# ─── Scheduler ────────────────────────────────────────────────────────────────
SIGNAL_REFRESH_SECONDS=30        # How often to recalculate signal (seconds)

# ─── Angel One SmartAPI ───────────────────────────────────────────────────────
USE_REAL_DATA=false
ANGEL_CLIENT_CODE=your_client_code
ANGEL_PASSWORD=your_password_or_mpin
ANGEL_API_KEY=your_smartapi_api_key
ANGEL_TOTP_SECRET=your_totp_secret_key

